module Payyr.Private.PayrollManager where

import DA.Foldable (foldr)
import DA.List (contains, filter)
import DA.Time
import Payyr.Private.EmployeeRegistry (EmployeeProfile)

sumSalary : [EmployeeProfile] -> Decimal
sumSalary = foldr (\ep acc -> ep.salary + acc) 0.0

template EmployerBalance
  with
    employer : Party
    balance : Decimal
  where
    signatory employer

template PayrollRun
  with
    employer : Party
    payrollId : Int
    timestamp : Time
    totalAmount : Decimal
    employeeCount : Int
    isCompleted : Bool
    authorizedAuditors : [Party]
    isPublic : Bool
  where
    signatory employer
    observer authorizedAuditors

    controller employer can
      GrantAuditorAccess : ContractId PayrollRun
        with
          auditor : Party
      do
        assertMsg "Auditor already authorized" (not (contains auditor authorizedAuditors))
        archive self
        create this with authorizedAuditors = auditor :: authorizedAuditors

      RevokeAuditorAccess : ContractId PayrollRun
        with
          auditor : Party
      do
        assertMsg "Auditor not authorized" (contains auditor authorizedAuditors)
        archive self
        create this with authorizedAuditors = filter (/= auditor) authorizedAuditors

      MakePayrollPublic : ContractId PayrollRun
      do
        archive self
        create this with isPublic = True

      IssueEmployeePayment : ContractId EmployeePayment
        with
          employee : Party
          amount : Decimal
      do
        assertMsg "Amount must be greater than 0" (amount > 0.0)
        create EmployeePayment with
          payrollId = payrollId
          employer = employer
          employee = employee
          amount = amount
          claimed = False

template EmployeePayment
  with
    payrollId : Int
    employer : Party
    employee : Party
    amount : Decimal
    claimed : Bool
  where
    signatory employer
    observer employee

    controller employee can
      Claim : ContractId EmployeePayment
      do
        assertMsg "Payroll already claimed" (not claimed)
        archive self
        create this with claimed = True

template PayrollManager
  with
    admin : Party
    currentPayrollId : Int
  where
    signatory admin

    controller admin can
      CreatePayrollRun : ContractId PayrollRun
        with
          employer : Party
          employeeProfiles : [EmployeeProfile]
      do
        let activeProfiles = filter (\rp -> rp.isActive) employeeProfiles
        let totalAmount = sumSalary activeProfiles
        assertMsg "No active employees" (length activeProfiles > 0)
        let nextPayrollId = currentPayrollId + 1
        payrollCid <- create PayrollRun with
          employer = employer
          payrollId = nextPayrollId
          timestamp = time
          totalAmount = totalAmount
          employeeCount = length activeProfiles
          isCompleted = True
          authorizedAuditors = []
          isPublic = False
        archive self
        create this with currentPayrollId = nextPayrollId
        pure payrollCid
        with
          employer : Party
          amount : Decimal
      do
        assertMsg "Amount must be greater than 0" (amount > 0.0)
        create EmployerBalance with
          employer = employer
          balance = amount
