module Payyr.Private.PayrollManager where

import DA.List (filter)
import Payyr.Private.EmployeeRegistry (EmployeeProfile, EmployeeWallet)

containsParty : Party -> [Party] -> Bool
containsParty _ [] = False
containsParty x (y :: ys) = x == y || containsParty x ys

nubParties : [Party] -> [Party]
nubParties [] = []
nubParties (x :: xs) = if containsParty x xs then nubParties xs else x :: nubParties xs

privatePayrollCurrency : Text
privatePayrollCurrency = "pUSD"

sumSalary : [EmployeeProfile] -> Decimal
sumSalary = foldr (\ep acc -> ep.salary + acc) 0.0

createPayments : [EmployeeProfile] -> Int -> Party -> Time -> Update [ContractId EmployeePayment]
createPayments [] _ _ = pure []
createPayments (rp :: rps) payrollId employer settledAt = do
  cid <- create EmployeePayment with
    payrollId = payrollId
    employer = employer
    employee = rp.employee
    amount = rp.salary
    paymentCurrency = rp.salaryCurrency
    claimed = False
    settled = True
    issuedAt = settledAt
    claimedAt = None
    settledAt = Some settledAt
    receiptReference = "PR-" <> show payrollId <> "-" <> rp.name
  rest <- createPayments rps payrollId employer settledAt
  pure (cid :: rest)

creditEmployeeWallets : [EmployeeProfile] -> Party -> Time -> Update ()
creditEmployeeWallets [] _ _ = pure ()
creditEmployeeWallets (rp :: rps) employer settledAt = do
  walletCidMb <- lookupByKey @EmployeeWallet (employer, rp.employee)
  case walletCidMb of
    None -> do
      create EmployeeWallet with
        employer = employer
        employee = rp.employee
        balance = rp.salary
        currency = rp.salaryCurrency
        lastPaidAt = Some settledAt
      creditEmployeeWallets rps employer settledAt
    Some walletCid -> do
      wallet <- fetch walletCid
      archive walletCid
      create EmployeeWallet with
        employer = wallet.employer
        employee = wallet.employee
        balance = wallet.balance + rp.salary
        currency = wallet.currency
        lastPaidAt = Some settledAt
      creditEmployeeWallets rps employer settledAt

template EmployerBalance
  with
    employer : Party
    balance : Decimal
    currency : Text
  where
    signatory employer

    key employer : Party
    maintainer key

    choice TopUp : ContractId EmployerBalance
      with
        amount : Decimal
      controller employer
      do
        assertMsg "Amount must be greater than 0" (amount > 0.0)
        create EmployerBalance with
          employer = employer
          balance = balance + amount
          currency = currency

template PayrollRun
  with
    employer : Party
    payrollId : Int
    timestamp : Time
    totalAmount : Decimal
    paymentCurrency : Text
    employeeCount : Int
    isCompleted : Bool
    authorizedAuditors : [Party]
    isPublic : Bool
  where
    signatory employer
    observer authorizedAuditors

    choice GrantAuditorAccess : ContractId PayrollRun
      with
        auditor : Party
      controller employer
      do
        assertMsg "Auditor already authorized" (not (containsParty auditor authorizedAuditors))
        create PayrollRun with
          employer = employer
          payrollId = payrollId
          timestamp = timestamp
          totalAmount = totalAmount
          paymentCurrency = paymentCurrency
          employeeCount = employeeCount
          isCompleted = isCompleted
          authorizedAuditors = auditor :: authorizedAuditors
          isPublic = isPublic

    choice RevokeAuditorAccess : ContractId PayrollRun
      with
        auditor : Party
      controller employer
      do
        assertMsg "Auditor not authorized" (containsParty auditor authorizedAuditors)
        create PayrollRun with
          employer = employer
          payrollId = payrollId
          timestamp = timestamp
          totalAmount = totalAmount
          paymentCurrency = paymentCurrency
          employeeCount = employeeCount
          isCompleted = isCompleted
          authorizedAuditors = filter (/= auditor) authorizedAuditors
          isPublic = isPublic

    choice MakePayrollPublic : ContractId PayrollRun
      controller employer
      do
        create PayrollRun with
          employer = employer
          payrollId = payrollId
          timestamp = timestamp
          totalAmount = totalAmount
          paymentCurrency = paymentCurrency
          employeeCount = employeeCount
          isCompleted = isCompleted
          authorizedAuditors = authorizedAuditors
          isPublic = True

    nonconsuming choice IssueEmployeePayment : ContractId EmployeePayment
      with
        employee : Party
        amount : Decimal
      controller employer
      do
        assertMsg "Amount must be greater than 0" (amount > 0.0)
        create EmployeePayment with
          payrollId = payrollId
          employer = employer
          employee = employee
          amount = amount
          paymentCurrency = paymentCurrency
          claimed = False

template EmployeePayment
  with
    payrollId : Int
    employer : Party
    employee : Party
    amount : Decimal
    paymentCurrency : Text
    claimed : Bool
    settled : Bool
    issuedAt : Time
    claimedAt : Optional Time
    settledAt : Optional Time
    receiptReference : Text
  where
    signatory employer
    observer employee

    choice Claim : ContractId EmployeePayment
      controller employee
      do
        assertMsg "Payroll already claimed" (not claimed)
        now <- getTime
        create EmployeePayment with
          payrollId = payrollId
          employer = employer
          employee = employee
          amount = amount
          paymentCurrency = paymentCurrency
          claimed = True
          settled = settled
          issuedAt = issuedAt
          claimedAt = Some now
          settledAt = settledAt
          receiptReference = receiptReference

template PayrollManager
  with
    admin : Party
    currentPayrollId : Int
  where
    signatory admin

    choice CreatePayrollRun : ContractId PayrollRun
      with
        employer : Party
        employeeProfiles : [EmployeeProfile]
        timestamp : Time
      controller admin
      do
        let activeProfiles = filter (\rp -> rp.isActive) employeeProfiles
        let totalAmount = sumSalary activeProfiles
        assertMsg "No active employees" (length activeProfiles > 0)
        employerBalanceCidMb <- lookupByKey @EmployerBalance employer
        employerBalanceCid <-
          case employerBalanceCidMb of
            None -> abort "Employer treasury not initialized"
            Some cid -> pure cid
        employerBalance <- fetch employerBalanceCid
        assertMsg "Insufficient employer treasury balance" (employerBalance.balance >= totalAmount)
        assertMsg "Employer treasury must use pUSD" (employerBalance.currency == privatePayrollCurrency)
        let nextPayrollId = currentPayrollId + 1
        payrollCid <- create PayrollRun with
          employer = employer
          payrollId = nextPayrollId
          timestamp = timestamp
          totalAmount = totalAmount
          paymentCurrency = privatePayrollCurrency
          employeeCount = length activeProfiles
          isCompleted = True
          authorizedAuditors = []
          isPublic = False
        archive employerBalanceCid
        create EmployerBalance with
          employer = employerBalance.employer
          balance = employerBalance.balance - totalAmount
          currency = employerBalance.currency
        paymentCids <- createPayments activeProfiles nextPayrollId employer timestamp
        creditEmployeeWallets activeProfiles employer timestamp
        create PayrollManager with
          admin = admin
          currentPayrollId = nextPayrollId
        pure payrollCid

    nonconsuming choice WithdrawPayroll : ContractId EmployerBalance
      with
        employer : Party
        amount : Decimal
      controller admin
      do
        assertMsg "Amount must be greater than 0" (amount > 0.0)
        employerBalanceCidMb <- lookupByKey @EmployerBalance employer
        case employerBalanceCidMb of
          None ->
            create EmployerBalance with
              employer = employer
              balance = amount
              currency = privatePayrollCurrency
          Some employerBalanceCid -> do
            employerBalance <- fetch employerBalanceCid
            archive employerBalanceCid
            create EmployerBalance with
              employer = employerBalance.employer
              balance = employerBalance.balance + amount
              currency = employerBalance.currency
