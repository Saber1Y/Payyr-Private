# Canton DevNet Environment Configuration
# Copy this to .env.local after deploying to DevNet

NEXT_PUBLIC_PRIVY_APP_ID=cmqjoegfc00000djlsq96qn98

# Canton DevNet JSON API endpoint (from Seaport or your validator)
NEXT_PUBLIC_DAML_API_URL=https://<your-devnet-api-url>
NEXT_PUBLIC_DAML_LEDGER_ID=canton

# Package ID from Seaport after deploying the DAR
NEXT_PUBLIC_DAML_PACKAGE_ID=<paste-package-id-from-seaport>

# Party map: wallet address -> Canton party ID
# Get party IDs from Seaport after allocating parties
NEXT_PUBLIC_DAML_PARTY_MAP={"<employer-wallet>":"<employer-party-id>","<employee-wallet>":"<employee-party-id>","<auditor-wallet>":"<auditor-party-id>"}

# Server-side API URL (same as above for DevNet)
DAML_API_URL=https://<your-devnet-api-url>

# JWT access token (from Seaport or Canton Console)
DAML_ACCESS_TOKEN=<paste-jwt-token>

# Wallet addresses (your Privy wallets)
DAML_EMPLOYER_WALLET=<employer-wallet-address>
DAML_EMPLOYEE_WALLET=<employee-wallet-address>
DAML_AUDITOR_WALLET=<auditor-wallet-address>
NEXT_PUBLIC_DAML_EMPLOYER_WALLET=<employer-wallet-address>
NEXT_PUBLIC_DAML_EMPLOYEE_WALLET=<employee-wallet-address>
NEXT_PUBLIC_DAML_AUDITOR_WALLET=<auditor-wallet-address>
